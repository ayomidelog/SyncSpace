# Authentication password for accessing the application
AUTH_PASSWORD=your_password_here

# Server port (default: 4111 for production, 4112 for development with Vite)
PORT=4111

# Allowed CORS origin (optional). Set to the URL of your frontend when it is
# served from a different origin, e.g. http://localhost:5173 for a Vite dev server.
# Leave unset (or empty) when the frontend is served by the same Express server.
# CORS_ORIGIN=

# Proxy trust setting (optional). Set to '1' when the server sits behind a
# single reverse proxy (e.g. nginx) so that req.ip reflects the real client IP
# for rate limiting. See https://expressjs.com/en/guide/behind-proxies.html
# TRUST_PROXY=1
